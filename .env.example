# SimbaScribe — environment variables.
#
# Copy this file to .env and fill in values. NEVER commit .env.
# Set permissions: chmod 600 .env
#
# Secrets and deploy-specific paths live HERE. Everything team/venture/language/
# channel/provider-specific lives in the WORKSPACE PROFILE (see below + docs/CONFIG.md),
# not in env.

# ─────────────────────────────────────────────────────────────────────────────
# Listener — Discord capture (Phase 1a). Always-on PM2 daemon.
# ─────────────────────────────────────────────────────────────────────────────

# Discord bot token (from the developer portal). Required.
# The MESSAGE_CONTENT privileged intent must be enabled on the bot.
DISCORD_BOT_TOKEN=

# Discord guild (server) snowflake ID. Required.
# Right-click the server icon in Discord → "Copy Server ID" (developer mode on).
DISCORD_GUILD_ID=

# Comma-separated list of channel snowflake IDs to listen on. Required.
# Right-click each channel → "Copy Channel ID". Whitespace around commas is allowed.
#
# Threads are captured via their PARENT: whitelisting a channel automatically
# captures every thread under it (existing and future) — you do NOT list thread IDs.
#
# For PRIVATE threads to deliver messages, the bot must be able to join them —
# grant the bot Manage Threads (plus View Channel + Read Message History) on the parent.
SIMBASCRIBE_WHITELIST_CHANNEL_IDS=

# Path to the SQLite database file. Required.
# Convention on the deploy box: <repo>/data/simbascribe.db
SIMBASCRIBE_DB_PATH=./data/simbascribe.db

# Log level for pino. Optional, defaults to "info".
# One of: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# Workspace profile — the config that carries everything team/venture/language/
# channel/provider-specific (see docs/CONFIG.md). The committed source ships a
# fictional example; point this at YOUR profile.
#
# Resolution order: this env var → config/workspace.local.json (if present) →
# otherwise the synth FAILS LOUD. It will NOT silently run on the fictional
# example. For a quick demo, set:
#   SIMBASCRIBE_WORKSPACE_PROFILE=profiles/example.workspace.json
# ─────────────────────────────────────────────────────────────────────────────
SIMBASCRIBE_WORKSPACE_PROFILE=

# Model provider API key. The PROFILE names which env var holds the key
# (provider.apiKeyEnv); the bundled example profile uses MODEL_API_KEY. The
# baseUrl and model name live in the profile, not here. Required even for
# --dry-run (a dry-run still calls the model — that's the point).
MODEL_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Synth — the digest writer (cron, twice daily). NOT read by the listener.
# ─────────────────────────────────────────────────────────────────────────────

# Discord webhook URL for the digest channel. Required for live posting (not for --dry-run).
# Channel settings → Integrations → Webhooks → New Webhook → Copy Webhook URL.
SIMBASCRIBE_OUTPUT_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Corpus snapshot + MCP server (read-only query layer for the Pulse agent).
# Both run as SEPARATE processes from the listener/synth.
# ─────────────────────────────────────────────────────────────────────────────

# Absolute path to the read-only corpus snapshot.
#   - The snapshot cron (src/snapshot, runs as the writer user) WRITES this every
#     2 min via `VACUUM INTO` + atomic rename — a standalone, non-WAL copy.
#     It is also the only backup of the corpus.
#   - The MCP server (src/mcp-server, runs as the sandboxed reader user) READS it,
#     opening it read-only per request and failing loud if it's missing.
# On the box this lives in a shared dir both users can reach, e.g.
#   /srv/ssbrain/snapshot.db   (dir: owner = writer, group = shared, mode 2750)
# Use the SAME absolute path in the writer's .env and the reader's MCP env.
SIMBASCRIBE_SNAPSHOT_DB_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# Tracker — the durable todo/idea/decision list (built + enabled).
#   - WRITE path: the synth reconcile maintains tracker.db from chat. Set
#     SIMBASCRIBE_TRACKER_DB_PATH to turn it on (the live deploy has it set).
#   - READ path: the snapshot cron publishes a read-only copy; the MCP server
#     exposes tracker_list / tracker_get over it.
#   - NAG-LOOP (aging + digest surfacing + ✅/❌ reactions): ships OFF by default.
#     Enable with SIMBASCRIBE_TRACKER_SURFACING_ENABLED=true (see below). With it
#     off, the tracker only captures + recalls (no posts, no nags) — same as today.
# ─────────────────────────────────────────────────────────────────────────────

# Writable tracker store (writer-owned). When set, the synth runs the (isolated)
# reconcile step and maintains this DB from chat. Unset → tracker step skipped.
SIMBASCRIBE_TRACKER_DB_PATH=

# Read-only tracker snapshot for the MCP server (reader side), same shared-dir
# pattern as the corpus snapshot. If unset/missing, the tracker_* MCP tools
# return a clear "tracker unavailable" error and the corpus tools keep working.
SIMBASCRIBE_TRACKER_SNAPSHOT_DB_PATH=

# The nag-loop. Default OFF. When "true", the isolated tracker step also ages the
# list, posts a surfacing summary + per-item ✅/❌ messages to the digest webhook,
# and reads reactions (via DISCORD_BOT_TOKEN, read-only) to apply pin/dismiss/
# confirm. A surfacing failure can never break the digest (it's swallowed).
# Requires SIMBASCRIBE_OUTPUT_WEBHOOK_URL (to post) and DISCORD_BOT_TOKEN (to read
# reactions). Leave OFF until you've verified the posts look right for your team.
SIMBASCRIBE_TRACKER_SURFACING_ENABLED=false

# ─────────────────────────────────────────────────────────────────────────────
# Knowledge base — a directory of curated markdown the agent can search/cite
# (runbooks, policies, how-tos), alongside the chat corpus + tracker. Read by the
# MCP server (the reader user), so the directory must be readable by it. Optional:
# if unset, the kb_* tools return "kb unavailable" and the rest keeps working.
#   - Demo:        SIMBASCRIBE_KB_PATH=kb/example
#   - In-repo KB:  put docs in kb/<name>.local/ (gitignored) and point here
#   - External:    any dir the reader user can read, e.g. /srv/ssbrain/kb
# ─────────────────────────────────────────────────────────────────────────────
SIMBASCRIBE_KB_PATH=

# ─────────────────────────────────────────────────────────────────────────────
# Model output ceilings (max_tokens). Optional — sensible defaults below.
# A run that EXCEEDS its ceiling throws and does NOT advance the watermark, so the
# next cron run re-summarizes the same (plus newer) window. That retry-by-cron is
# the intended safety behaviour, but an under-sized ceiling on a busy/chatty team
# can wedge it into a compounding loop where every run is too big. If you see
# repeated "hit max_tokens" errors, raise the relevant ceiling here (no code edit).
# Must be a positive integer; an invalid value fails loud at startup.
#   - Digest (src/synth):    default 8192
#   - Tracker reconcile:     default 4096
# ─────────────────────────────────────────────────────────────────────────────
SIMBASCRIBE_DIGEST_MAX_TOKENS=
SIMBASCRIBE_TRACKER_MAX_TOKENS=
